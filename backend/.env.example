# Google Gemini API key — required
# Get one at: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=

# Comma-separated list of origins allowed to call this API.
# Local dev default is http://localhost:5173
# In Railway (production), set to your Vercel domain, e.g.:
#   ALLOWED_ORIGINS=https://teachers-pet.vercel.app,https://teachers-pet-<hash>.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Server port (Railway injects $PORT automatically — only used for local dev)
SERVER_PORT=8000
SERVER_HOST=0.0.0.0

# Optional: Postgres for long-term storage (falls back to local SQLite when unset)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Optional: Redis cache for active chat sessions (falls back to in-memory cache)
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=
CHAT_CACHE_TTL_SECONDS=86400

# Firebase Admin auth verification for authenticated chat/session APIs.
# Option A: Service account JSON payload (single-line JSON string)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: Application default credentials
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
