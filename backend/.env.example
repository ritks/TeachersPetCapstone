# Google Gemini API key — required
# Get one at: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=

# Comma-separated list of origins allowed to call this API.
# Local dev default is http://localhost:5173
# In Railway (production), set to your Vercel domain, e.g.:
#   ALLOWED_ORIGINS=https://teachers-pet.vercel.app,https://teachers-pet-<hash>.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Server port (Railway injects $PORT automatically — only used for local dev)
SERVER_PORT=8000
SERVER_HOST=0.0.0.0
