# Backend API base URL. Local dev: http://localhost:8000
# In Vercel (production), set to your Railway backend URL, e.g. https://teachers-pet-api.up.railway.app
VITE_API_BASE_URL=http://localhost:8000

# Firebase web app config (safe to expose — these are client-side keys, gated by Firebase security rules)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
